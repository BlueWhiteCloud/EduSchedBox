{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist-electron",
    "strict": false,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noImplicitAny": false,
    "allowJs": true
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules", "src", "**/*.vue"]
}